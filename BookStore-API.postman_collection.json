{
  "info": {
    "name": "BookStore API — Session 1",
    "_postman_id": "bookstore-session-1",
    "description": "Full collection for the Session 1 BookStore REST API (Books + Authors).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "bookId",
      "value": "",
      "type": "string",
      "description": "Paste a real _id here after creating a book"
    },
    {
      "key": "authorId",
      "value": "",
      "type": "string",
      "description": "Paste a real _id here after creating an author"
    }
  ],
  "item": [
    {
      "name": "Books",
      "item": [
        {
          "name": "List all books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"]
            },
            "description": "Returns a paginated list of all books."
          }
        },
        {
          "name": "List books — paginated",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Page 1, 5 results per page."
          }
        },
        {
          "name": "List books — filter by genre",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books?genre=Technology",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"],
              "query": [
                { "key": "genre", "value": "Technology" }
              ]
            },
            "description": "Exact match on the genre field."
          }
        },
        {
          "name": "List books — full-text search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books?search=clean code",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"],
              "query": [
                { "key": "search", "value": "clean code" }
              ]
            },
            "description": "MongoDB $text search across title and author fields."
          }
        },
        {
          "name": "List books — filter by author",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books?author=martin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"],
              "query": [
                { "key": "author", "value": "martin" }
              ]
            },
            "description": "Case-insensitive partial match on the author field."
          }
        },
        {
          "name": "Get a single book",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "description": "Fetch one book by its MongoDB _id. Set the bookId variable first."
          }
        },
        {
          "name": "Create a book",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data._id) {",
                  "  pm.collectionVariables.set('bookId', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"The Pragmatic Programmer\",\n  \"author\": \"David Thomas\",\n  \"isbn\": \"9780135957059\",\n  \"price\": 35.00,\n  \"genre\": \"Technology\",\n  \"publishedYear\": 2019\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"]
            },
            "description": "Creates a new book. Automatically saves the returned _id into the bookId variable."
          }
        },
        {
          "name": "Update a book (PUT — full)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"The Pragmatic Programmer\",\n  \"author\": \"David Thomas\",\n  \"isbn\": \"9780135957059\",\n  \"price\": 39.99,\n  \"genre\": \"Technology\",\n  \"publishedYear\": 2019\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "description": "Full replacement — all fields required."
          }
        },
        {
          "name": "Update a book (PATCH — partial)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 24.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "description": "Partial update — only the fields you send are changed."
          }
        },
        {
          "name": "Delete a book",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books", "{{bookId}}"]
            },
            "description": "Deletes the book matching bookId."
          }
        }
      ]
    },
    {
      "name": "Authors",
      "item": [
        {
          "name": "List all authors",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors"]
            },
            "description": "Returns a paginated list of all authors, sorted by name."
          }
        },
        {
          "name": "List authors — paginated",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "List authors — filter by nationality",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors?nationality=Egyptian",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors"],
              "query": [
                { "key": "nationality", "value": "Egyptian" }
              ]
            },
            "description": "Exact match on the nationality field."
          }
        },
        {
          "name": "List authors — search by name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors?name=martin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors"],
              "query": [
                { "key": "name", "value": "martin" }
              ]
            },
            "description": "Case-insensitive partial match on the name field."
          }
        },
        {
          "name": "Get a single author",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors/{{authorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors", "{{authorId}}"]
            },
            "description": "Fetch one author by _id. Set the authorId variable first."
          }
        },
        {
          "name": "Create an author",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data._id) {",
                  "  pm.collectionVariables.set('authorId', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Robert C. Martin\",\n  \"bio\": \"Known as Uncle Bob. Author of Clean Code and Clean Architecture.\",\n  \"nationality\": \"American\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors"]
            },
            "description": "Creates a new author. Automatically saves the returned _id into the authorId variable."
          }
        },
        {
          "name": "Update an author (PUT — full)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Robert C. Martin\",\n  \"bio\": \"Known as Uncle Bob. Wrote Clean Code, The Clean Coder, and Clean Architecture.\",\n  \"nationality\": \"American\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors/{{authorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors", "{{authorId}}"]
            }
          }
        },
        {
          "name": "Update an author (PATCH — partial)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nationality\": \"American\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors/{{authorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors", "{{authorId}}"]
            }
          }
        },
        {
          "name": "Delete an author",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/authors/{{authorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "authors", "{{authorId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Server health check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Returns a simple message confirming the server is up."
          }
        }
      ]
    }
  ]
}
